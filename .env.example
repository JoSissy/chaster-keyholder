# ── Chaster ──────────────────────────────────────────────────────────────────
# Token de usuario — obtén el tuyo en: https://chaster.app/settings/api
CHASTER_TOKEN=tu_token_aqui

# Extensions API — solo necesario para freeze/hidetime/pillory
# Crea tu extensión en: https://chaster.app/developers
CHASTER_EXTENSION_TOKEN=tu_extension_token_aqui
CHASTER_EXTENSION_SLUG=tu-extension-slug

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del bot — créalo con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui

# Username del bot sin @ (ej: mi_keyholder_bot)
TELEGRAM_BOT_USERNAME=tu_bot_username

# Tu Chat ID — consíguelo escribiéndole a @userinfobot en Telegram
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ── Groq ──────────────────────────────────────────────────────────────────────
# API Key para los modelos LLaMA — obtén la tuya en: https://console.groq.com
GROQ_API_KEY=gsk_tu_key_aqui

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Para almacenar fotos de tareas y juguetes — cuenta gratis en: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── Base de datos ─────────────────────────────────────────────────────────────
# En Railway con volumen persistente usa: /app/keyholder.db
DB_PATH=/app/keyholder.db

# ── Servidor web ──────────────────────────────────────────────────────────────
PORT=8080
